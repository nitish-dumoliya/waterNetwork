# Pipe's parameters: start node, end node, length (m)
# Diameters are decision variables chosen from the candidate set below (Table 10)
# From Table A6
param: arcs:                             L    vmax:=
        1              2              165       2
        2              3              124       2
        3              4              118       2
        4              5               81       2
        5              6              134       2
        6             12              135       2
       12             15              202       2
